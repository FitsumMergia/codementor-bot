# Copy to .env and fill in. Never commit the real .env.

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=

# A random string you choose. Telegram echoes it back in the
# X-Telegram-Bot-Api-Secret-Token header so we can verify the caller.
TELEGRAM_SECRET_TOKEN=change-me-to-a-random-string

# Anthropic API key (the SDK also reads ANTHROPIC_API_KEY from the env directly)
ANTHROPIC_API_KEY=

# Default: zero-friction local SQLite. For staging/prod use MySQL (Bronze plan):
# DATABASE_URL=mysql+pymysql://user:pass@host:3306/codementor
DATABASE_URL=sqlite:///./codementor.db

# Token guarding the /admin/metrics endpoint
ADMIN_TOKEN=change-me-admin-token

# Public URL where THIS FastAPI app is reachable (tunnel or host),
# used by set_webhook.py when you point Telegram straight at the backend.
# If you put the Cloudflare Worker in front, point the webhook at the Worker instead.
BACKEND_PUBLIC_URL=https://your-tunnel.example.com
